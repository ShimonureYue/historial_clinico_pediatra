# ── Backend ───────────────────────────────────────────────
# Puerto del servidor (default: 8000)
PORT=8000

# Clave secreta para JWT (cambiar en produccion)
SECRET_KEY=historial-pediatrico-secret-key-change-in-production

# Ruta a la base de datos SQLite (default: database/historial_pediatrico.db relativo al proyecto)
# DB_PATH=/ruta/absoluta/a/historial_pediatrico.db

# ── Frontend (Vite) ──────────────────────────────────────
# Puerto del backend para desarrollo (default: 8000)
VITE_API_PORT=8000
