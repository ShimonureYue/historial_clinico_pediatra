# ── Historia Clinica Pediatrica — Configuracion ──────────
# Copia este archivo como ".env" y ajusta los valores.
# NUNCA subas .env a git (ya esta en .gitignore).

# ── Backend ───────────────────────────────────────────────
# Puerto del servidor (default: 8000)
PORT=8000

# Clave secreta para JWT (cambiar en produccion)
SECRET_KEY=historial-pediatrico-secret-key-change-in-production

# Ruta a la base de datos SQLite (default: database/historial_pediatrico.db)
# DB_PATH=

# ── Frontend (solo desarrollo) ───────────────────────────
VITE_API_PORT=8000

# ── Respaldos a AWS S3 (opcional) ────────────────────────
# Deja vacios si no usas respaldos a la nube.
# La pagina de Respaldos mostrara un aviso si no estan configurados.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BACKUP_BUCKET=historial-pediatrico-backups
S3_BACKUP_PREFIX=clinic-01
AWS_DEFAULT_REGION=us-east-1
